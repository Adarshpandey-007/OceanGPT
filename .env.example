NEXT_PUBLIC_API_BASE=http://localhost:3000

# --- Backend / Future ---
# FUTURE_BACKEND_URL=http://localhost:8000
# Postgres / PostGIS (docker-compose exposes on 5433 by default)
DATABASE_URL=postgres://floatchat:floatchat_dev@localhost:5433/floatchat
POSTGRES_USER=floatchat
POSTGRES_PASSWORD=floatchat_dev
POSTGRES_DB=floatchat
# VECTOR_STORE_PATH=./vector_store

# --- LLM Keys (DO NOT COMMIT REAL SECRETS) ---
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Real data directory (NetCDF files)
ARGO_DATA_DIR=./ARGO-DATA

# Directory where parsed profile JSON caches will be written by offline ingestion script
PROFILE_CACHE_DIR=./data/derived/profiles

# Notes:
# 1. Real keys belong in .env.local (ignored by git).
# 2. The Gemini key you pasted in chat is now exposed; rotate it in Google AI Studio before production use.